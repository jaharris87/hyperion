serial_16: CFLAGS += -DSIZE=16
serial_16: libhyburn
	$(CC) -c $(SOURCE_DIR)/main.c -o $(OBJECT_DIR)/main.o $(CFLAGS) 
	$(LD) $(OBJECT_DIR)/main.o -o $(OBJECT_DIR)/serial_16 $(LD_FLAGS) $(LD_LIBS)

